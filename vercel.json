{
  "version": 2,
  "outputDirectory": "src/main/resources/static",
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://keygames-production.up.railway.app/:path*",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/uploads/:path*",
      "destination": "https://keygames-production.up.railway.app/uploads/:path*"
    }
  ]
}
