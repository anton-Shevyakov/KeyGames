{
  "version": 2,
  "buildCommand": "node scripts/vercel-config.js",
  "outputDirectory": "src/main/resources/static",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://keygames-production.up.railway.app/api/:path*"
    },
    {
      "source": "/games",
      "destination": "https://keygames-production.up.railway.app/games"
    },
    {
      "source": "/games/:path*",
      "destination": "https://keygames-production.up.railway.app/games/:path*"
    },
    {
      "source": "/orders",
      "destination": "https://keygames-production.up.railway.app/orders"
    },
    {
      "source": "/orders/:path*",
      "destination": "https://keygames-production.up.railway.app/orders/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://keygames-production.up.railway.app/uploads/:path*"
    }
  ]
}
